{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seplan.itapoa/motor-cad/input-manifest.schema.json",
  "title": "Motor CAD Input Manifest v0.1",
  "type": "object",
  "required": ["documents"],
  "additionalProperties": false,
  "properties": {
    "manifest_version": { "type": "string", "pattern": "^0\\.1$" },
    "project_id": { "type": "string", "minLength": 1 },
    "project_name": { "type": "string", "minLength": 1 },
    "processing_version": { "type": "string", "minLength": 1 },
    "output_root": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/document" }
    },
    "expected": { "$ref": "#/$defs/expected" },
    "export": { "$ref": "#/$defs/export" },
    "audit": { "$ref": "#/$defs/audit" }
  },
  "$defs": {
    "clean": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coord_tol": { "type": "number", "exclusiveMinimum": 0 },
        "gap_tol": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "scale": {
      "oneOf": [
        { "type": "null" },
        { "type": "number", "exclusiveMinimum": 0 },
        {
          "type": "object",
          "required": ["numerator", "denominator"],
          "additionalProperties": false,
          "properties": {
            "numerator": { "type": "number", "exclusiveMinimum": 0 },
            "denominator": { "type": "number", "exclusiveMinimum": 0 },
            "unit": { "type": "string" }
          }
        }
      ]
    },
    "region": {
      "type": "object",
      "required": ["bbox", "origin"],
      "additionalProperties": false,
      "properties": {
        "region_id": { "type": "string", "minLength": 1 },
        "region_type": { "type": "string", "minLength": 1 },
        "drawing_type": { "type": "string", "minLength": 1 },
        "building_block": { "type": "string", "minLength": 1 },
        "level_id": { "type": "string", "minLength": 1 },
        "level_name": { "type": "string", "minLength": 1 },
        "bbox": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "origin": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "scale": { "$ref": "#/$defs/scale" },
        "output_name": { "type": "string", "minLength": 1 },
        "output_dir": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "page": {
      "type": "object",
      "required": ["page_index", "regions"],
      "additionalProperties": false,
      "properties": {
        "page_index": { "type": "integer", "minimum": 0 },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/region" }
        },
        "notes": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "document": {
      "type": "object",
      "required": ["source_pdf", "pages"],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string", "minLength": 1 },
        "source_pdf": { "type": "string", "minLength": 1 },
        "source_pdf_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "output_dir": { "type": "string", "minLength": 1 },
        "clean": { "$ref": "#/$defs/clean" },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/page" }
        },
        "notes": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "expected": { "$ref": "#/$defs/expected" },
        "export": { "$ref": "#/$defs/export" },
        "audit": { "$ref": "#/$defs/audit" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "final_lines": { "type": "integer", "minimum": 0 },
        "layers": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dxf_format": { "type": "string" },
        "target": { "type": "string" },
        "write_svg": { "type": "boolean" }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "save_region_report": { "type": "boolean" },
        "save_run_summary": { "type": "boolean" },
        "capture_manifest_snapshot": { "type": "boolean" }
      }
    }
  }
}
